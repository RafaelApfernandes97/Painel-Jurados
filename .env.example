# ============================
# Backend (API)
# ============================
PORT=3000
NODE_ENV=production

# MongoDB connection string
MONGO_URI=mongodb://USER:PASSWORD@HOST:PORT/painel_jurados?tls=true

# JWT secret (min 32 chars): openssl rand -base64 48
JWT_SECRET=

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://client.seudominio.com,https://jury.seudominio.com,https://admin.seudominio.com

# Jury panel base URL (used for generating judge access links)
JURY_BASE_URL=https://jury.seudominio.com/jury

# SuperAdmin seed credentials
SUPERADMIN_EMAIL=admin@seudominio.com
SUPERADMIN_PASSWORD=

# ============================
# Client Web (Frontend)
# ============================
VITE_CLIENT_API_URL=https://api.seudominio.com
VITE_CLIENT_SOCKET_URL=https://api.seudominio.com
VITE_CLIENT_JURY_URL=https://jury.seudominio.com/jury

# ============================
# Jury Web (Frontend)
# ============================
VITE_JURY_API_URL=https://api.seudominio.com
VITE_JURY_SOCKET_URL=https://api.seudominio.com

# ============================
# SuperAdmin Web (Frontend)
# ============================
VITE_SUPERADMIN_API_URL=https://api.seudominio.com

# ============================
# Ports (optional, for docker-compose)
# ============================
API_PORT=3000
CLIENT_PORT=8081
JURY_PORT=8082
SUPERADMIN_PORT=8083
