PORT=3000
NODE_ENV=production

# MongoDB connection string
MONGO_URI=mongodb://USER:PASSWORD@HOST:PORT/painel_jurados?tls=true

# JWT secret (min 32 chars): openssl rand -base64 48
JWT_SECRET=

# CORS - comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://client.ritmusgestao.com.br,https://juri.ritmusgestao.com.br,https://admin.ritmusgestao.com.br

# Jury panel base URL (used for generating judge access links)
JURY_BASE_URL=https://juri.ritmusgestao.com.br/jury

# SuperAdmin seed credentials
SUPERADMIN_EMAIL=admin@ritmusgestao.com.br
SUPERADMIN_PASSWORD=
